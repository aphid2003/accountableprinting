# MongoDB Atlas connection string (Atlas dashboard → Connect → Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=print_monitoring

# Comma-separated keys that desktop apps must send in the X-API-Key header.
# Start with one shared key, or generate one per device for finer control.
DEVICE_API_KEYS=change-this-to-a-long-random-string

# Private key for the admin/monitoring dashboard (X-Admin-Key header). Keep secret.
ADMIN_API_KEY=change-this-to-a-different-long-random-string

PORT=8000
